# Core app
ENV=dev
LOG_LEVEL=INFO
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Database (usado para montar DATABASE_URL por default)
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=econtrole
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SUA_SENHA_AQUI

# Opcional: sobrescreve totalmente a conexao
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5434/econtrole

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]

# Seed (dev)
SEED_ENABLED=true
SEED_ORG_NAME=Neto Contabilidade
MASTER_EMAIL=SEU_EMAIL_REAL_AQUI
MASTER_PASSWORD=SUA_SENHA_AQUI
MASTER_ROLES=DEV,ADMIN

# ReceitaWS bulk sync
RECEITAWS_MIN_INTERVAL_SECONDS=20
RECEITAWS_RATE_LIMIT_BACKOFF_SECONDS=60

# CertHub / certificados
CERTHUB_BASE_URL=https://certhub.local/api/v1
CERTHUB_API_TOKEN=
CERTHUB_CERTS_LIST_URL_TEMPLATE=
CERTHUB_AUTH_LOGIN_URL=
CERTHUB_EMAIL=
CERTHUB_PASSWORD=
CERTHUB_VERIFY_TLS=true
# opcional: caminho para CA bundle
# CERTHUB_CA_BUNDLE=C:\path\to\ca-bundle.pem
CERT_MIRROR_UPDATE_COMPANY_PROFILES=true

# Portal do Cidadão / Tax Portal Sync
PORTAL_CIDADAO_USUARIO=
PORTAL_CIDADAO_SENHA=
API_KEY_2CAPTCHA=
TAX_PORTAL_DEFAULT_MUNICIPIO=ANÁPOLIS
TAX_PORTAL_MIN_INTERVAL_SECONDS=0
TAX_PORTAL_MAX_TENTATIVAS=2
TAX_PORTAL_MODO_TESTE=false
TAX_PORTAL_MODO_HEADLESS=true
TAX_PORTAL_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Copilot eControle - provider principal (Gemini 2.5 Flash)
COPILOT_PROVIDER=gemini
COPILOT_PROVIDER_MODEL=gemini-2.5-flash
COPILOT_PROVIDER_TIMEOUT_SECONDS=60
GEMINI_API_KEY=
COPILOT_PROVIDER_ENABLE_WEB_SEARCH=true

# Copilot eControle - fallback opcional local (Ollama)
COPILOT_FALLBACK_PROVIDER=ollama
COPILOT_FALLBACK_BASE_URL=http://127.0.0.1:11434
COPILOT_FALLBACK_MODEL=gemma3:4b
COPILOT_FALLBACK_TIMEOUT_SECONDS=60
